{
  "name": "komper-market-lens",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n bff,web -c cyan,magenta \"tsx watch --env-file-if-exists=.env src/server/index.ts\" \"vite\"",
    "build": "vite build && tsup src/server/index.ts --format esm --out-dir dist/server --clean --sourcemap",
    "start": "node --env-file-if-exists=.env dist/server/index.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:e2e": "pnpm run build",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.3.0",
    "@fontsource/orbitron": "^5.3.0",
    "@highcharts/react": "^5.2.2",
    "@tanstack/react-query": "^5.66.9",
    "decimal.js": "^10.5.0",
    "express": "^4.21.2",
    "highcharts": "^13.0.0",
    "json-bigint": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.21.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@playwright/test": "^1.50.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/express": "^5.0.0",
    "@types/json-bigint": "^1.0.4",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/supertest": "^7.2.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.20.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.15.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.0",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.3.6",
    "tsx": "^4.19.3",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  }
}
