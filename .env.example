# Local application
PORT=3000
MARKET_DATA_MODE=fixture

# Browser live updates. Keep this aligned with MARKET_LIVE_SSE_ENABLED.
VITE_LIVE_COMPARISONS=false

# Experimental live market pipeline. Keep disabled for normal local development.
MARKET_LIVE_INGEST_ENABLED=false
MARKET_LIVE_RANKING_ENABLED=false
MARKET_LIVE_SSE_ENABLED=false
MARKET_LIVE_ASSETS=BTC,ETH,USDT
MARKET_LIVE_VENUES=INDODAX,REKU,TOKOCRYPTO

# Optional: required only for the Indodax public WebSocket live worker.
INDODAX_PUBLIC_WS_TOKEN=

# Live pipeline tuning (milliseconds unless stated otherwise).
MARKET_LIVE_STALE_MS=15000
MARKET_LIVE_SSE_CADENCE_MS=1000
MARKET_LIVE_SSE_SLOW_MS=5000
MARKET_TYPE3_REST_POLL_MS=10000
MARKET_REKU_MAX_CONNECTIONS=8
